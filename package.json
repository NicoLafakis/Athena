{
  "name": "athena",
  "version": "1.0.0",
  "description": "Athena — AI-powered desktop assistant with full system control",
  "main": "main.js",
  "scripts": {
    "dev": "electron .",
    "build": "electron-builder --win",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.athena.chatbot",
    "productName": "Athena",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "resources/**/*",
      ".env"
    ],
    "extraResources": [
      {
        "from": "resources/",
        "to": "resources/",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "resources/icon.ico"
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "@vitejs/plugin-react": "^4.2.0",
    "tailwindcss": "^3.4.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "concurrently": "^8.2.0",
    "vite": "^5.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "electron-store": "^8.1.0",
    "dotenv": "^16.3.0",
    "fs-extra": "^11.2.0",
    "chokidar": "^3.5.0",
    "screenshot-desktop": "^1.15.0",
    "tesseract.js": "^5.0.0",
    "@nut-tree-fork/nut-js": "^4.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  }
}
